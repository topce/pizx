{
  "name": "@topce/pizx",
  "version": "0.9.1",
  "description": "zx fork with native Pi AI integration — shell scripting with AI agents, multi-agent orchestration, and 15+ agent pattern template tags (Ralph, Fleet, Subagent, Debate, Pipeline, Orchestrator, Critique, Thread, Memory, Broadcast, Adaptive, Graph, Nu, Chi, Tau)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./globals": {
      "types": "./dist/globals.d.ts",
      "import": "./dist/globals.js",
      "default": "./dist/globals.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "pizx": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:dts",
    "build:js": "node scripts/build.mjs",
    "build:dts": "tsc --project tsconfig.build.json",
    "dev": "node scripts/build.mjs --watch",
    "lint": "biome ci src/ && eslint src/",
    "lint:biome": "biome ci src/",
    "lint:eslint": "eslint src/",
    "lint:fix": "biome lint --write src/ && eslint --fix src/",
    "check": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:integration": "PIZX_INTEGRATION=1 vitest --run src/patterns.integration.test.ts",
    "test:coverage": "vitest --run --coverage",
    "prepublishOnly": "npm run build",
    "example:hello": "node dist/cli.js examples/hello-pizx.mjs",
    "example:pi": "node dist/cli.js examples/basic-pi.mjs",
    "example:Pi": "node dist/cli.js examples/basic-capital-pi.mjs",
    "example:quick": "node dist/cli.js examples/quick-ask.mjs",
    "example:ralph": "node dist/cli.js examples/ralph-loop.mjs",
    "example:pattern-ralph": "node dist/cli.js examples/pattern-ralph.mjs",
    "example:pattern-fleet": "node dist/cli.js examples/pattern-fleet.mjs",
    "example:pattern-subagent": "node dist/cli.js examples/pattern-subagent.mjs",
    "example:pattern-debate": "node dist/cli.js examples/pattern-debate.mjs",
    "example:pattern-pipeline": "node dist/cli.js examples/pattern-pipeline.mjs",
    "example:pattern-critique": "node dist/cli.js examples/pattern-critique.mjs",
    "example:pattern-orchestrator": "node dist/cli.js examples/pattern-orchestrator.mjs",
    "example:all": "npm run example:hello && npm run example:pi && npm run example:Pi && npm run example:quick && npm run example:ralph && npm run example:pattern-ralph && npm run example:pattern-fleet && npm run example:pattern-subagent && npm run example:pattern-debate && npm run example:pattern-pipeline && npm run example:pattern-critique && npm run example:pattern-orchestrator && npm run example:pattern-thread && npm run example:pattern-memory && npm run example:pattern-broadcast && npm run example:pattern-adaptive && npm run example:pattern-graph && npm run example:pattern-nu && npm run example:pattern-chi && npm run example:pattern-tau && npm run example:tracking && npm run example:quality && npm run example:timeout-retry && npm run example:system-propagation && npm run example:five-whys && npm run example:agent-with-skill",
    "example:pattern-thread": "node dist/cli.js examples/pattern-thread.mjs",
    "example:pattern-memory": "node dist/cli.js examples/pattern-memory.mjs",
    "example:pattern-broadcast": "node dist/cli.js examples/pattern-broadcast.mjs",
    "example:pattern-adaptive": "node dist/cli.js examples/pattern-adaptive.mjs",
    "example:pattern-graph": "node dist/cli.js examples/pattern-graph.mjs",
    "example:pattern-nu": "node dist/cli.js examples/pattern-nu.mjs",
    "example:pattern-chi": "node dist/cli.js examples/pattern-chi.mjs",
    "example:pattern-tau": "node dist/cli.js examples/pattern-tau.mjs",
    "example:tracking": "node dist/cli.js examples/pattern-tracking.mjs",
    "example:quality": "node dist/cli.js examples/pattern-quality.mjs",
    "example:timeout-retry": "node dist/cli.js examples/pattern-timeout-retry.mjs",
    "example:system-propagation": "node dist/cli.js examples/pattern-system-propagation.mjs",
    "example:five-whys": "node dist/cli.js examples/pattern-five-whys.mjs",
    "example:agent-with-skill": "node dist/cli.js examples/pattern-agent-with-skill.mjs",
    "test:quality": "node dist/cli.js examples/test-quality.mjs",
    "test:confirm": "node dist/cli.js examples/test-confirm.mjs",
    "test:confirm-all": "node dist/cli.js examples/test-confirm-all.mjs",
    "example:execution-modes": "node dist/cli.js examples/pattern-execution-modes.mjs",
    "example:execution-modes-en": "node dist/cli.js english-examples/execution-modes.mjs",
    "example:goal-en": "node dist/cli.js english-examples/goal.mjs",
    "example:ralph-guards-en": "node dist/cli.js english-examples/ralph-guards.mjs",
    "example:loop-engineering": "node dist/cli.js examples/pattern-loop-engineering.mjs",
    "test:composition-fleet": "node dist/cli.js examples/test-composition-fleet.mjs",
    "test:composition-pipeline": "node dist/cli.js examples/test-composition-pipeline.mjs",
    "test:new-features": "npm run test:quality && npm run test:confirm && npm run test:confirm-all && npm run test:composition-fleet && npm run test:composition-pipeline"
  },
  "keywords": [
    "zx",
    "pi",
    "ai",
    "pi-ai",
    "pi-coding-agent",
    "shell",
    "script",
    "cli",
    "automation",
    "llm",
    "multi-agent",
    "orchestration",
    "agent-patterns",
    "coding-agent",
    "template-tag",
    "ai-scripting",
    "shell-scripting",
    "agentic-workflow",
    "fleet",
    "ralph-loop"
  ],
  "author": "Slobodan Filipovic <topce@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/topce/pizx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/topce/pizx.git"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2",
    "zx": "8.8.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "0.28.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "4.1.9"
  }
}
